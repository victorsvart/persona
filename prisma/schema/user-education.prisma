model UserEducation {
    id              String    @id
    university_name String
    enrollment      DateTime  @default(now())
    completion      DateTime?
    finished        Boolean
    description     String?
    userId          String
    User            User      @relation(fields: [userId], references: [id])
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @default(now()) @updatedAt

    @@map("user_education")
    @@schema("public")
}
